# DuckClaw Admin UI — copiar a .env.local (no commitear)
# Documentación: docs/environment.md

# Base URL del API Gateway (mismo host que pm2 DuckClaw-Gateway)
# URL completa del gateway (preferida) o puerto + host:
DUCKCLAW_GATEWAY_URL=http://127.0.0.1:8000
# DUCKCLAW_GATEWAY_PORT=8000
# DUCKCLAW_GATEWAY_HOST=127.0.0.1

# Debe coincidir con DUCKCLAW_ADMIN_API_KEY en el .env raíz del monorepo
DUCKCLAW_ADMIN_API_KEY=change-me-local-admin-key

# Seed login (hub DuckDB) — nunca commitear valores reales
# DUCKCLAW_ADMIN_EMAIL=admin@duckclaw.local
# DUCKCLAW_ADMIN_PASSWORD=change-me-min-8-chars

# Auth / sesiones (gateway)
# SESSION_TTL_SECONDS=43200
# ENV=development
# GATEWAY_INTERNAL_URL=http://127.0.0.1:8000

# Dev hint en login (solo development + SHOW_DEV_HINT=true)
# SHOW_DEV_HINT=false
# NEXT_PUBLIC_DEV_HINT_EMAIL=admin@duckclaw.local

# Opcional: ruta al monorepo (el gateway resuelve plantillas; útil en despliegues atípicos)
# DUCKCLAW_REPO_ROOT=../..

# --- Solo si reactivas el módulo CRM PQRSD (ver docs/legacy-crm-module.md) ---
# NEXT_PUBLIC_IA_HABILITADA=true
# CRM_DUCKDB_PATH=db/private/<vault_user_id>/pqrsd-assistantdb1.duckdb
# CRM_VAULT_USER_ID=<vault_user_id>
# DUCKCLAW_GATEWAY_USER_ID_OVERRIDE=<user_id_en_whitelist_PQRS>
